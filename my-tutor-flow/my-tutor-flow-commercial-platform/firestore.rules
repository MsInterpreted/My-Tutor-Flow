rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Check if user is a tutor
    function isTutor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tutor';
    }

    // Helper: Check if user is admin or tutor
    function isStaff() {
      return isAdmin() || isTutor();
    }

    // Helper: Check if the requesting user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Validate string field
    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile during signup
      allow create: if isOwner(userId);
      // Users can update their own profile, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user documents
      allow delete: if isAdmin();
    }

    // User profiles collection (used by authorization service)
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile during signup
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Authorization logs (authenticated users can create during signup)
    match /authorizationLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Students collection
    match /students/{studentId} {
      // Staff can read all students
      allow read: if isStaff();
      // Staff can create students
      allow create: if isStaff();
      // Staff can update students
      allow update: if isStaff();
      // Only admins can delete students
      allow delete: if isAdmin();

      // Student subcollections (marks, attendance, etc.)
      match /{subcollection}/{docId} {
        allow read: if isStaff();
        allow create, update: if isStaff();
        allow delete: if isAdmin();
      }
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Marks collection
    match /marks/{markId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Billing / Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Parent communication logs
    match /parentLogs/{logId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Documents / files metadata
    match /documents/{documentId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Authorization codes
    match /authorizationCodes/{codeId} {
      // Authenticated users can read codes (needed for signup validation)
      allow read: if isAuthenticated();
      // Only admins can create/modify codes
      allow write: if isAdmin();
    }

    // App settings / configuration
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
